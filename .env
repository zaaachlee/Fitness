# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./fitness.db
DATABASE_URL_SYNC=sqlite:///./fitness.db

# JWT
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# AI Provider — choose one: claude | openai | deepseek | openai-compatible
# ========================================
AI_PROVIDER=deepseek

# Claude API (used when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# DeepSeek
OPENAI_API_KEY=sk-6e8405dbf0794f41832125b8c25517b5
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
