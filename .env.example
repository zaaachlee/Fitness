# Database
DATABASE_URL=postgresql+asyncpg://fitness:fitness_secret@db:5432/fitness_db
DATABASE_URL_SYNC=postgresql://fitness:fitness_secret@db:5432/fitness_db

# JWT
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
